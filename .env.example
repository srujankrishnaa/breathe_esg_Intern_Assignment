# ── Backend (Railway) Environment Variables ──────────────────

# Database configuration — Railway auto-provisions Postgres
# and sets DATABASE_URL automatically when you add a Postgres plugin
DATABASE_URL=postgres://user:password@localhost:5432/breathe_esg

# Django Secret Key — generate a random one for production
DJANGO_SECRET_KEY=your-django-secret-key-here

# Allowed Hosts (comma-separated) — include your Railway domain
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app

# Django Debug mode — MUST be false in production
DEBUG=false

# CORS — set to your Netlify frontend URL (with https://)
CORS_ALLOWED_ORIGINS=https://your-app.netlify.app

# CSRF trusted origins — same as CORS for cross-origin POST
CSRF_TRUSTED_ORIGINS=https://your-app.netlify.app

# ── Frontend (Netlify) Environment Variables ─────────────────

# Must be set in Netlify Build Environment Settings
# This is baked into the JS bundle at build time, not runtime
VITE_API_BASE_URL=https://your-app.railway.app/api
