# Database configuration
# Local SQLite fallback is used if this is empty
DATABASE_URL=postgres://user:password@localhost:5432/breathe_esg

# Django Secret Key
DJANGO_SECRET_KEY=your-django-secret-key-here

# Allowed Hosts (comma-separated)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# Django Debug mode (true/false)
DEBUG=true

# CORS configuration (comma-separated allowed origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Frontend Environment Variable
# Must be set in Vite environment or system env
VITE_API_BASE_URL=http://localhost:8000/api
